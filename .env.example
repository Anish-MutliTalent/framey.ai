# ── Framey AI configuration ──────────────────────────────────────────────
# Copy to .env and fill in. The AE driver defaults to the simulator (no
# After Effects needed); a Fireworks API key is required for the agent.

# LLM provider: Fireworks AI (OpenAI-compatible) running a MiniMax model.
FRAMEY_LLM=fireworks

# Fireworks AI OpenAI-compatible endpoint.
FRAMEY_BASE_URL=https://api.fireworks.ai/inference/v1

# Your Fireworks API key (https://fireworks.ai). Required — the agent will not run without one.
FRAMEY_API_KEY=

# MiniMax model on Fireworks. Defaults to the newest, minimax-m3 (524K ctx, vision).
FRAMEY_MODEL=accounts/fireworks/models/minimax-m3

# After Effects driver.
#   simulate      = in-process AE simulator (no AE needed; fully runnable)
#   extendscript  = drive a real running After Effects via the JSX bridge
FRAMEY_AE_DRIVER=simulate

# Local TCP port the AE ExtendScript driver connects to (extendscript mode only).
FRAMEY_BRIDGE_PORT=49321
